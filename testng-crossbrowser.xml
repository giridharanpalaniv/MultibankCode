<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-crossbrowser.xml
  =======================
  Runs all UI tests across Chrome, Firefox, and Edge in parallel.
  Usage: mvn test -DsuiteXmlFile=testng-crossbrowser.xml
-->
<suite name="MultiBank-CrossBrowser-Suite" verbose="1"
       parallel="tests" thread-count="3">

    <!-- Chrome -->
    <test name="Chrome-Navigation">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>
    <test name="Chrome-Trading">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>
    <test name="Chrome-Content">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.ContentValidationTest"/>
        </classes>
    </test>

    <!-- Firefox -->
    <test name="Firefox-Navigation">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>
    <test name="Firefox-Trading">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>
    <test name="Firefox-Content">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.ContentValidationTest"/>
        </classes>
    </test>

    <!-- Edge -->
    <test name="Edge-Navigation">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>
    <test name="Edge-Trading">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>
    <test name="Edge-Content">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.ContentValidationTest"/>
        </classes>
    </test>

</suite>
